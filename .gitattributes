# Normalize line endings to LF in the repository regardless of the
# checkout platform (this project develops on Windows, deploys/CI on Linux).
* text=auto eol=lf

# Known binary types — never touch line endings or attempt diffing.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.xlsx binary
*.pdf binary
