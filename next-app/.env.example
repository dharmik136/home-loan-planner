# Values prefixed with NEXT_PUBLIC_ are bundled into the browser application.
# Use only the Supabase project URL and a publishable key here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key
NEXT_PUBLIC_SITE_URL=https://home-loan-planner-neon.vercel.app

# Never add a Supabase secret key, service_role key, database password, or
# personal access token to this file or to any NEXT_PUBLIC_ variable.
